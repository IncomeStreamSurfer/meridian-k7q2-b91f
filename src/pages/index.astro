---
import Base from '../layouts/Base.astro';

const renderedAt = Date.now();

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Meridian',
    url: 'https://meridian.coffee',
    logo: 'https://meridian.coffee/logo.png',
    sameAs: [],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Meridian',
    url: 'https://meridian.coffee',
    description: 'Coffee, at the edge of dawn.',
  },
];
---

<Base
  title="Meridian Coffee | Coming Soon"
  description="Meridian is a new specialty coffee brand launching soon. Join the list for early access, founder stories, and launch-day discounts."
  structuredData={structuredData}
>
  <!-- HERO -->
  <section class="mx-auto max-w-6xl px-6 pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="grid gap-14 md:grid-cols-[1.15fr_0.85fr] md:items-end">
      <div>
        <span class="inline-block text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-accent)]">Launching soon</span>
        <h1 class="font-display mt-5 text-[13vw] leading-[0.92] tracking-tight md:text-[5.2rem]">
          <span class="block">Meridian</span>
          <span class="block italic font-normal text-[7vw] md:text-[2.75rem] mt-2 muted-ink">Specialty coffee, launching soon</span>
        </h1>
        <p class="mt-8 max-w-md text-lg leading-relaxed muted-ink">
          Coffee, at the edge of dawn. We're a small-batch roaster built around one idea: you should know exactly whose farm your coffee came from, and taste the difference that honesty makes.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-6">
          <a href="#signup" class="inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-7 py-3.5 text-sm font-medium text-[#fbf6ee] transition hover:bg-[var(--color-accent-dim)] hover:-translate-y-0.5">
            Join the early list
          </a>
          <a href="/story" class="text-sm font-medium underline decoration-[var(--color-line)] underline-offset-4 transition hover:decoration-[var(--color-accent)]">
            Read the Meridian story →
          </a>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-[4/5] w-full overflow-hidden border border-[var(--color-line)] hero-border">
          <img
            src="https://picsum.photos/seed/meridian-dawn-roast/900/1125"
            alt="Freshly roasted single-origin coffee beans cooling before packing at Meridian"
            class="h-full w-full object-cover grayscale-[15%]"
            loading="eager"
            width="900"
            height="1125"
          />
        </div>
        <p class="mt-3 text-xs muted-ink">First harvest lot, high-altitude Yirgacheffe — arriving with launch.</p>
      </div>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="border-t border-[var(--color-line)] section-border">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <h2 class="font-display text-2xl md:text-3xl max-w-xl">Three things that won't change once we launch</h2>
      <div class="mt-12 grid gap-0 md:grid-cols-3">
        <div class="border-t border-[var(--color-line)] section-border py-8 pr-8 md:border-t-0 md:border-l md:pl-8 md:pt-0 md:first:border-l-0 md:first:pl-0">
          <span class="font-display text-sm text-[var(--color-accent)]">01</span>
          <h3 class="mt-3 text-lg font-medium">Names on every bag</h3>
          <p class="mt-3 text-sm leading-relaxed muted-ink">Every origin lot carries the farm or cooperative name, altitude, and the price we paid. No blends hiding behind marketing copy.</p>
        </div>
        <div class="border-t border-[var(--color-line)] section-border py-8 md:border-t-0 md:border-l md:px-8">
          <span class="font-display text-sm text-[var(--color-accent)]">02</span>
          <h3 class="mt-3 text-lg font-medium">Roasted in lots under 20kg</h3>
          <p class="mt-3 text-sm leading-relaxed muted-ink">Small batches mean the roast curve is tuned to that specific lot, not a house average. Consistency comes from care, not volume.</p>
        </div>
        <div class="border-t border-[var(--color-line)] section-border py-8 pl-0 md:border-t-0 md:border-l md:pl-8">
          <span class="font-display text-sm text-[var(--color-accent)]">03</span>
          <h3 class="mt-3 text-lg font-medium">Shipped within 72 hours of roast</h3>
          <p class="mt-3 text-sm leading-relaxed muted-ink">Coffee peaks days after roasting, not months. We roast to order and ship fast so what arrives is close to what we cupped.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- STORY TEASER -->
  <section id="story" class="border-t border-[var(--color-line)] section-border">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid gap-10 md:grid-cols-2 md:gap-16">
        <div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-accent)]">Why we started this</span>
          <h2 class="font-display mt-4 text-3xl leading-[1.05] md:text-4xl">A brand built at 5am, not in a boardroom</h2>
        </div>
        <div class="space-y-5 text-base leading-relaxed muted-ink">
          <p>
            Meridian started as an argument between two people who couldn't agree on what "specialty coffee" should mean. One had spent a decade buying green coffee direct from growers in Ethiopia and Colombia. The other had spent that same decade behind a roaster, chasing the exact moment a bean stops tasting green and starts tasting like itself.
          </p>
          <p>
            What we agreed on: most "specialty" coffee brands sell you a mood board, not a farm. We're building the opposite — a brand where the sourcing story is the product, and the editorial polish is just how we tell it honestly.
          </p>
          <a href="/story" class="inline-block text-sm font-medium underline decoration-[var(--color-line)] underline-offset-4 transition hover:decoration-[var(--color-accent)]">
            Meet the founders and read the full Meridian coffee story →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SIGNUP -->
  <section id="signup" class="border-t border-[var(--color-line)] section-border">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
      <div class="mx-auto max-w-xl text-center">
        <h2 class="font-display text-3xl md:text-4xl">Get early access to Meridian</h2>
        <p class="mt-4 text-base leading-relaxed muted-ink">
          Join the list and you'll be first to hear about our launch date, first-batch discount, and the founder notes behind each origin we bring in.
        </p>

        <form id="signup-form" method="POST" action="/api/subscribe" class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center" novalidate>
          <input type="hidden" name="renderedAt" value={renderedAt} />
          <input
            type="text"
            name="website"
            aria-hidden="true"
            tabindex="-1"
            autocomplete="off"
            style="position:absolute; left:-9999px; opacity:0; pointer-events:none"
          />
          <label for="email" class="sr-only">Email address</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@example.com"
            class="w-full rounded-full border border-[var(--color-line)] bg-transparent px-5 py-3.5 text-sm outline-none transition focus:border-[var(--color-accent)] sm:w-72"
          />
          <button
            type="submit"
            class="rounded-full bg-[var(--color-accent)] px-7 py-3.5 text-sm font-medium text-[#fbf6ee] transition hover:bg-[var(--color-accent-dim)] hover:-translate-y-0.5"
          >
            Join the list
          </button>
        </form>
        <p id="signup-status" class="mt-4 text-sm" role="status" aria-live="polite"></p>
        <p class="mt-3 text-xs muted-ink">
          By joining, you agree to our <a href="/privacy-policy" class="underline decoration-[var(--color-line)] underline-offset-4 hover:decoration-[var(--color-accent)]">privacy policy</a>. No spam, one email at launch.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .muted-ink { color: var(--color-ink-muted); }
  :global(body.theme-dark) .muted-ink { color: var(--color-dark-ink-muted); }
  .hero-border { border-color: var(--color-line); }
  :global(body.theme-dark) .hero-border { border-color: var(--color-dark-line); }
  .section-border { border-color: var(--color-line); }
  :global(body.theme-dark) .section-border { border-color: var(--color-dark-line); }
</style>

<script>
  const form = document.getElementById('signup-form') as HTMLFormElement | null;
  const status = document.getElementById('signup-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    status.textContent = 'Joining\u2026';
    status.classList.remove('text-red-500');

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      if (res.ok && json.ok) {
        window.location.href = '/thank-you';
        return;
      }
      status.textContent = json.error || 'Something went wrong — please try again.';
      status.classList.add('text-red-500');
    } catch (err) {
      status.textContent = 'Something went wrong — please try again.';
      status.classList.add('text-red-500');
    }
  });
</script>
